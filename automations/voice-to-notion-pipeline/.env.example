# .env.example
# Copy this file to .env and replace the values with your actual credentials.
# DO NOT commit your .env file to version control.

# OpenAI API Key (for Whisper and GPT structuring)
OPENAI_API_KEY=your_openai_api_key_here

# Notion API Details (for saving the structured idea)
NOTION_API_KEY=your_notion_api_key_here
NOTION_DATABASE_ID=your_notion_db_id_here
