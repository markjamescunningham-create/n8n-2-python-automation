# .env.example
# Copy this file to .env and replace the values with your actual credentials.
# DO NOT commit your .env file to version control.

# Clearbit API Key (for enrichment)
CLEARBIT_API_KEY=your_clearbit_api_key_here

# OpenAI API Key (for lead scoring)
OPENAI_API_KEY=your_openai_api_key_here

# Slack Webhook URL (for routing hot leads)
SLACK_WEBHOOK_URL=your_slack_webhook_url_here

# ActiveCampaign API Details (for nurturing low-score leads)
ACTIVECAMPAIGN_URL=https://youraccount.api-us1.com
ACTIVECAMPAIGN_API_KEY=your_activecampaign_api_key_here
