# Slack bot token (from api.slack.com/apps → OAuth & Permissions)
SLACK_BOT_TOKEN=xoxb-your-token-here

# Channel to post to (name or ID)
SLACK_CHANNEL=#general

# Comma-separated list of RSS feed URLs
RSS_FEED_URLS=https://feeds.feedburner.com/TechCrunch/,https://www.marketingweek.com/feed/

# Path to the file that tracks seen items
STATE_FILE=seen_items.json
