# Copy this file to .env and fill in your values
# NEVER commit your real .env file

# Target site to scrape
START_URL=https://quotes.toscrape.com/tag/humor/

# CSS selector for the "next page" link (href attribute)
NEXT_PAGE_SELECTOR=li.next a

# Google Sheets (for output)
GOOGLE_CREDENTIALS_JSON=credentials.json
SPREADSHEET_ID=your_spreadsheet_id_here
SHEET_NAME=Sheet1

# Delay between page requests (seconds) — be polite!
DELAY_SECONDS=1
