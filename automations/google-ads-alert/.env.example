# Google Ads Developer Token (API Centre → APPLY FOR BASIC ACCESS)
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token-here

# OAuth2 Bearer access token for your Google Ads account
# For production use, implement refresh token rotation — access tokens expire after 1 hour
GOOGLE_ADS_ACCESS_TOKEN=ya29.your-access-token-here

# 10-digit Google Ads customer/account ID (hyphens optional)
GOOGLE_ADS_CUSTOMER_ID=123-456-7890

# Alert thresholds — campaigns exceeding either will trigger a Slack alert
CPA_THRESHOLD_USD=50.0
CPC_THRESHOLD_USD=5.0

# Slack (leave blank to print alerts to stdout only)
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL=#marketing-alerts

# Local fallback output
OUTPUT_FILE=ads_report.json
