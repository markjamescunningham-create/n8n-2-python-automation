# SerpAPI key — serpapi.com (free: 100 searches/month)
SERPAPI_KEY=your-serpapi-key-here

# OpenAI API key
OPENAI_API_KEY=sk-your-openai-key-here

# Model to use (gpt-4o-mini is fast and cheap; gpt-4o for higher quality)
OPENAI_MODEL=gpt-4o-mini

# Number of top SERP results to analyse per keyword
SERP_RESULTS=10

# Default keyword (can be overridden with --keyword flag)
KEYWORD=best CRM for startups

# Directory to write brief markdown files to
OUTPUT_DIR=briefs
