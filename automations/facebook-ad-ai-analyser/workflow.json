        {
            "id": "b2f42335-8b1e-4d00-a9a8-f7f631f1927d",
            "name": "Getting Data For the Past 28 Days",
            "type": "n8n-nodes-base.httpRequest",
            "position": [
                -1120,
                528
            ],
            "parameters": {
                "url": "=https://graph.facebook.com/v22.0/act_YOUR_AD_ACCOUNT_ID/insights",
                "options": {},
                "sendQuery": true,
                "sendHeaders": true,
                "queryParameters": {
                    "parameters": [
                        {
                            "name": "level",
                            "value": "ad"
                        },
                        {
                            "name": "fields",
                            "value": "campaign_name,adset_name,ad_name,ad_id,objective,spend,impressions,clicks,actions,action_values,date_start,date_stop"
                        },
                        {
                            "name": "date_preset",
                            "value": "last_28d"
                        },
                        {
                            "name": "limit",
                            "value": "500"
                        }
                    ]
                },
                "headerParameters": {
                    "parameters": [
                        {
                            "name": "Authorization",
                            "value": "=Bearer {{ $json.accessToken }}"
                        }
                    ]
                }
            },
            "typeVersion": 4.2
        },
        {
            "id": "ce1cff8f-e076-4ec5-9a86-58db01605894",
            "name": "Splitting Out In Table Format",
            "type": "n8n-nodes-base.code",
            "position": [
                -896,
                528
            ],
            "parameters": {
                "jsCode": "const allN8NInputItems = $input.all();\nconst finalOutputItems = [];\nconst ATC_TYPES = ['omni_add_to_cart','offsite_conversion.fb_pixel_add_to_cart'];\nconst CHECKOUT_TYPES = ['omni_initiated_checkout','offsite_conversion.fb_pixel_initiate_checkout'];\nconst PURCHASE_TYPES = ['omni_purchase','offsite_conversion.fb_pixel_purchase','purchase'];\nfunction getCount(actions, types) { if (!actions) return 0; for (const t of types) { const a = actions.find(x => x.action_type === t); if (a) return parseInt(a.value || 0); } return 0; }\nfunction getValue(actionValues, types) { if (!actionValues) return 0; for (const t of types) { const a = actionValues.find(x => x.action_type === t); if (a) return parseFloat(a.value || 0); } return 0; }\nfor (const n8nItem of allN8NInputItems) { const data = n8nItem.json.data || []; for (const fbData of data) { finalOutputItems.push({ json: { ad_id: fbData.ad_id, ad_name: fbData.ad_name, campaign_name: fbData.campaign_name, objective: fbData.objective, spend: parseFloat(fbData.spend || 0), impressions: parseInt(fbData.impressions || 0), clicks: parseInt(fbData.clicks || 0), add_to_carts_count: getCount(fbData.actions, ATC_TYPES), checkouts_initiated_count: getCount(fbData.actions, CHECKOUT_TYPES), purchases_count: getCount(fbData.actions, PURCHASE_TYPES), purchase_value_total: getValue(fbData.action_values, PURCHASE_TYPES) } }); } }\nreturn finalOutputItems;"
            },
            "typeVersion": 2
        },
        {
            "id": "2fdd3e2f-92fa-4034-841a-500dad9f91bc",
            "name": "Filtering Only For Sales Campaigns",
            "type": "n8n-nodes-base.filter",
            "position": [
                -704,
                528
            ],
            "parameters": {
                "options": {},
                "conditions": {
                    "options": {
                        "version": 2,
                        "caseSensitive": true,
                        "typeValidation": "strict"
                    },
                    "combinator": "and",
                    "conditions": [
                        {
                            "id": "7e4103af",
                            "operator": {
                                "name": "filter.operator.equals",
                                "type": "string",
                                "operation": "equals"
                            },
                            "leftValue": "={{ $json.objective }}",
                            "rightValue": "OUTCOME_SALES"
                        }
                    ]
                }
            },
            "typeVersion": 2.2
        },
        {
            "id": "cf388ebd-dff0-4658-b13a-59619c8cf701",
            "name": "Aggregate Metrics by Ad Creative",
            "type": "n8n-nodes-base.code",
            "position": [
                -496,
                448
            ],
            "parameters": {
                "jsCode": "const allInputItems = $input.all();\nconst agg = {};\nfor (const n8nItem of allInputItems) { const d = n8nItem.json; const key = d.ad_name; if (!agg[key]) { agg[key] = { ad_name: d.ad_name, ad_id: d.ad_id, objective: d.objective, total_spend: 0, total_impressions: 0, total_clicks: 0, total_add_to_carts: 0, total_checkouts_initiated: 0, total_purchases: 0, total_purchase_value: 0 }; } agg[key].total_spend += d.spend; agg[key].total_impressions += d.impressions; agg[key].total_clicks += d.clicks; agg[key].total_add_to_carts += d.add_to_carts_count; agg[key].total_checkouts_initiated += d.checkouts_initiated_count; agg[key].total_purchases += d.purchases_count; agg[key].total_purchase_value += d.purchase_value_total; }\nconst out = [];\nfor (const key in agg) { const a = agg[key]; a.roas = a.total_spend > 0 ? parseFloat((a.total_purchase_value / a.total_spend).toFixed(2)) : 0; a.cost_per_purchase = a.total_purchases > 0 ? parseFloat((a.total_spend / a.total_purchases).toFixed(2)) : 0; a.conversion_rate = a.total_clicks > 0 ? (a.total_purchases / a.total_clicks * 100).toFixed(2) + '%' : '0%'; a.total_spend = parseFloat(a.total_spend.toFixed(2)); out.push({ json: a }); }\nreturn out;"
            },
            "typeVersion": 2
        },
        {
            "id": "83a6b0a8-8422-4705-9576-deca22f7f092",
            "name": "Sorting Based on Spends",
            "type": "n8n-nodes-base.sort",
            "position": [
                -304,
                448
            ],
            "parameters": {
                "options": {},
                "sortFieldsUi": {
                    "sortField": [
