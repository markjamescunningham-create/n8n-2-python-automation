        {
            "id": "e0d95e0a-4cc2-42a7-9f6d-337bb1dc68b9",
            "name": "Does it Need A Token Refresh?",
            "type": "n8n-nodes-base.code",
            "position": [
                -2704,
                768
            ],
            "parameters": {
                "jsCode": "const tokenData = $input.first()?.json || {};\nconst now = new Date().getTime();\nconst endDate = new Date(tokenData.end_date).getTime();\nconst threeDaysInMs = 3 * 24 * 60 * 60 * 1000;\nconst timeToExpiry = endDate - now;\nconst needsRefresh = timeToExpiry > 0 && timeToExpiry <= threeDaysInMs;\nreturn [{ json: { needs_refresh: needsRefresh, expires_at: tokenData.end_date } }];"
            },
            "typeVersion": 2
        },
