        {
            "id": "2eaabe3c-fec3-4804-8f2b-db39a00cb0c4",
            "name": "Calculate Account Benchmarks",
            "type": "n8n-nodes-base.code",
            "position": [
                -464,
                784
            ],
            "parameters": {
                "jsCode": "const records = $input.all();\nconst totals = { spend: 0, impressions: 0, clicks: 0, purchases: 0, purchase_value: 0 };\nfor (const n of records) { totals.spend += n.json.spend || 0; totals.impressions += n.json.impressions || 0; totals.clicks += n.json.clicks || 0; totals.purchases += n.json.purchases_count || 0; totals.purchase_value += n.json.purchase_value_total || 0; }\nconst kpis = { ...totals, roas: totals.spend > 0 ? parseFloat((totals.purchase_value / totals.spend).toFixed(2)) : 0, cost_per_purchase: totals.purchases > 0 ? parseFloat((totals.spend / totals.purchases).toFixed(2)) : 0, conversion_rate: totals.clicks > 0 ? (totals.purchases / totals.clicks * 100).toFixed(2) + '%' : '0%' };\nreturn [{ json: kpis }];"
            },
            "typeVersion": 2
        },
        {
            "id": "23411043-d16f-40f4-8fcc-3c6653f3595c",
            "name": "Stringify Benchmark Data",
            "type": "n8n-nodes-base.code",
            "position": [
