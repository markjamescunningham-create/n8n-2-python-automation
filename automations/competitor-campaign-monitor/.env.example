# Copy this file to .env and fill in your values
# NEVER commit your real .env file

# OpenRouter (AI analysis and report generation)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-4o

# Slack (report delivery)
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here
SLACK_CHANNEL_ID=your_channel_id_here

# Input — CSV file with a "Page URL" column
TARGETS_CSV=targets.csv

# Snapshot file (stores previous scrape data for comparison)
SNAPSHOT_FILE=previous_data.json

# Delay between page requests (seconds)
DELAY_SECONDS=2
