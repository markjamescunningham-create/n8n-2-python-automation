# Copy this file to .env and fill in your values
# NEVER commit your real .env file

# OpenRouter (AI analysis)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-4o

# Airtable (output)
AIRTABLE_TOKEN=your_airtable_personal_access_token_here
AIRTABLE_BASE_ID=your_airtable_base_id_here
AIRTABLE_TABLE_ID=your_airtable_table_id_here

# Google Sheets (staging database — optional if using CSV only)
GOOGLE_CREDENTIALS_JSON=credentials.json
SPREADSHEET_ID=your_spreadsheet_id_here

# Input — CSV file with a "Page URL" column (optionally a "Company" column)
TARGETS_CSV=targets.csv

# Delay between requests (seconds)
DELAY_SECONDS=2
