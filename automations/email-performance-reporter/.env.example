# Mailchimp API key — find under Account → Extras → API keys
MAILCHIMP_API_KEY=your-mailchimp-api-key-here

# Data centre prefix (last part of the API key, e.g. us1, us6)
MAILCHIMP_SERVER=us1

# Optional: filter to a specific audience/list ID
MAILCHIMP_LIST_ID=

# Number of sent campaigns to pull
CAMPAIGN_LIMIT=10

# n8n webhook URL that appends rows to Google Sheets (leave blank to skip)
SHEETS_WEBHOOK_URL=https://your-n8n-instance.com/webhook/email-report

# Local fallback output file
OUTPUT_FILE=report.json
