# OpenAI API key
OPENAI_API_KEY=sk-your-openai-key-here

# Model to use (gpt-4o-mini is cheap and accurate; gpt-4o for complex transcripts)
OPENAI_MODEL=gpt-4o-mini

# Default transcript file path (can be overridden with --transcript flag or stdin)
TRANSCRIPT_FILE=meeting.txt

# CSV file to append action items to
OUTPUT_CSV=action_items.csv

# Notion integration token (optional — leave blank to skip Notion)
NOTION_API_KEY=secret_your-notion-integration-token

# Notion database ID to write tasks to
# (find in the database URL: notion.so/<workspace>/<DATABASE_ID>?v=...)
NOTION_DB_ID=your-notion-database-id-here
